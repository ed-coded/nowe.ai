# Copy this file to .env.local and fill in real values before running the app.
# .env.local is gitignored — never commit real credentials.

# --- Supabase ---
# Find these in your Supabase project dashboard:
# Project Settings -> API -> Project URL / Publishable key
# (https://supabase.com/dashboard/project/_/settings/api-keys)

# The base URL of your Supabase project, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The project's publishable key (safe to expose in browser code — replaces
# the legacy "anon" key). Starts with "sb_publishable_".
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Admin portal ---
# Server-only second factor required (in addition to a normal admin
# Supabase account) to reach /noweadmin. Never exposed to the browser.
# Pick a long, random value — do not reuse a value that has ever been typed
# into a chat, ticket, or shared doc. Rotate by editing this value only, no
# code changes needed.
ADMIN_ACCESS_PASSPHRASE=
